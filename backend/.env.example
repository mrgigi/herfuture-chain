PORT=3000

# Supabase Configurations
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Blockchain Configurations (Celo Sepolia Testnet / Mainnet)
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
ADMIN_PRIVATE_KEY=your_admin_wallet_private_key_here

# Smart Contract Addresses
CREDENTIAL_REGISTRY_ADDRESS=0xYourCredentialRegistryContractAddress
GRANT_DISBURSEMENT_ADDRESS=0xYourGrantDisbursementContractAddress

# IPFS Configurations (e.g. Pinata)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here
